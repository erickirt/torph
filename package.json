{
  "private": true,
  "packageManager": "pnpm@9.10.0",
  "type": "module",
  "scripts": {
    "install:all": "pnpm -r install",
    "watch": "pnpm --filter=torph dev",
    "dev": "pnpm run watch & pnpm run site:dev",
    "build": "pnpm --filter=torph build",
    "site:dev": "pnpm --filter=site dev",
    "site:build": "pnpm run build && pnpm --filter=site build",
    "example:react": "pnpm --filter=react-example dev",
    "example:svelte": "pnpm --filter=svelte-example dev",
    "example:svelte-ssr": "pnpm --filter=svelte-ssr-example dev",
    "example:typescript": "pnpm --filter=typescript-example dev",
    "example:vue": "pnpm --filter=vue-example dev",
    "lint": "pnpm --filter=torph lint",
    "lint:fix": "pnpm --filter=torph lint:fix",
    "pre-commit": "pnpm run --filter=torph pre-commit",
    "version": "changeset version && git add --all",
    "release": "pnpm build && changeset publish && git push --follow-tags"
  },
  "devDependencies": {
    "@changesets/cli": "^2.26.2",
    "@commitlint/cli": "^17.8.0",
    "@commitlint/config-conventional": "^17.8.0",
    "lint-staged": "^15.0.2"
  }
}
